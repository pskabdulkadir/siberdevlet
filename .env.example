# ============ PROJECT GAIA v9.5 CONFIGURATION ============

# ⚠️ AI & Backend (İSTEĞE BAĞLI)
# Gemini API anahtarı sağlamasan da sistem açık kaynak AI (ChatEverywhere) ile çalışır
# GEMINI_API_KEY="MY_GEMINI_API_KEY" # (isteğe bağlı)
# APP_URL="MY_APP_URL"

# 🆓 AÇIK KAYNAK AI KÖŞESİ
# Sistem otomatik olarak şu kaynakları dener:
# 1. ChatEverywhere API (https://chateverywhere.app/api/chat) - Ücretsiz, anahtarsız
# 2. Yerel Ollama (http://localhost:11434) - Kurulu ise otomatik kullanılır
# 3. Procedural fallback - Hiçbir API çalışmıyorsa sistem kendi algoritmasını kullanır

# ============ DATABASE PERSISTENCE (Kalıcılık) ============
# PostgreSQL connection string for absolute state persistence
DATABASE_URL="postgresql://user:password@localhost:5432/gaia_db"

# ============ FINANCIAL INTEGRATION ============
STRIPE_SECRET_KEY=sk_live_your_stripe_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/your-api-key
OWNER_CRYPTO_PRIVATE_KEY=0x... # For blockchain payout signing

# ============ PAYOUT SETTINGS ============
OWNER_IBAN=TR62000...
OWNER_CRYPTO_WALLET=0xYourCryptoWalletAddress...
AUTO_PAYOUT=true

# ============ FAST-BOOT & BACKUP ============
# Backup directory (will be created if not exists)
BACKUP_DIR=./data
# Backup interval in minutes (default: 5)
BACKUP_INTERVAL=5

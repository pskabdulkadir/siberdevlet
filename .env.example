# 🌐 SERVER
# PORT=3000

# 🆓 AÇIK KAYNAK AI (Varsayılan: ChatEverywhere + Ollama fallback)
# GEMINI_API_KEY= # (isteğe bağlı)

# 💾 DATABASE (Varsayılan: In-Memory Mode)
# DATABASE_URL=postgresql://user:password@localhost:5432/gaia_db

# 💳 ÖDEME SİSTEMLERİ (isteğe bağlı)
# STRIPE_SECRET_KEY=
# POLYGON_RPC_URL=

# ============ DATABASE PERSISTENCE (Kalıcılık) ============
# PostgreSQL connection string for absolute state persistence
DATABASE_URL="postgresql://user:password@localhost:5432/gaia_db"

# ============ FINANCIAL INTEGRATION ============
STRIPE_SECRET_KEY=sk_live_your_stripe_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/your-api-key
OWNER_CRYPTO_PRIVATE_KEY=0x... # For blockchain payout signing

# ============ PAYOUT SETTINGS ============
OWNER_IBAN=TR62000...
OWNER_CRYPTO_WALLET=0xYourCryptoWalletAddress...
AUTO_PAYOUT=true

# ============ FAST-BOOT & BACKUP ============
# Backup directory (will be created if not exists)
BACKUP_DIR=./data
# Backup interval in minutes (default: 5)
BACKUP_INTERVAL=5
